  "tip_siyah_mekonyum_title": "First Poop",
  "tip_siyah_mekonyum_desc": "In the first 2-4 days, this is normal whether your baby takes breast milk or formula. No need to worry.",
  "tip_eye_tracking_title": "Eye Tracking",
  "tip_eye_tracking_desc": "Your baby can clearly see only about 25-30 cm for now. Move your face slowly and let your baby follow with their eyes.",
  "tip_neck_support_title": "Neck Support",
  "tip_neck_support_desc": "Always support your baby's head and neck when holding them. Neck muscles are still very weak.",
  "tip_reflex_stepping_title": "Stepping Reflex",
  "tip_reflex_stepping_desc": "Hold your baby upright and let their feet touch a flat surface. You may see stepping reflexes.",
  "tip_sound_interest_title": "Interest in Sounds",
  "tip_sound_interest_desc": "Your baby is very sensitive to sounds. Try getting attention with a soft rattle or gentle music box.",
  "tip_parent_interaction_title": "Parent Interaction",
  "tip_parent_interaction_desc": "Make eye contact and talk softly. Your baby recognizes your voice and feels secure with it.",
  "tip_color_worlds_title": "World of Colors",
  "tip_color_worlds_desc": "Newborns see high-contrast black and white patterns best. Try showing black-and-white cards.",
  "tip_mini_athlete_title": "Mini Athlete",
  "tip_mini_athlete_desc": "Tummy time strengthens neck and back muscles. Try a few minutes each day.",
  "tip_sound_hunter_title": "Sound Hunter",
  "tip_sound_hunter_desc": "Snap softly near your baby's ear. They may try turning toward the sound.",
  "tip_touch_explore_title": "Touch Exploration",
  "tip_touch_explore_desc": "Let your baby feel different textures on hands and feet: soft, rough, and cool surfaces.",
  "tip_agu_conversation_1_2_title": "Baby Talk Chats",
  "tip_agu_conversation_1_2_desc": "When your baby makes sounds, listen. Reply gently when they finish. These tiny chats build communication.",
  "tip_tummy_time_strength_1_2_title": "Strong Shoulders (Tummy Time)",
  "tip_tummy_time_strength_1_2_desc": "Place your baby on their tummy for short periods. Encourage head lifting with colorful toys in front.",
  "tip_baby_massage_1_2_title": "Soothing Massage",
  "tip_baby_massage_1_2_desc": "After bath time, massage gently starting from the feet. It supports body awareness and helps your baby relax.",
  "tip_gesture_speech_1_2_title": "Gesture-Based Talking",
  "tip_gesture_speech_1_2_desc": "Use gestures while talking. Wave for \"we're going\" and rub hands for \"all done\". This supports visual memory.",
  "tip_open_hands_1_2_title": "Free Fingers",
  "tip_open_hands_1_2_desc": "Hands are opening more now. Offer soft toys to practice grasping and releasing.",
  "tip_side_by_side_bonding_1_2_title": "Side-by-Side Bonding",
  "tip_side_by_side_bonding_1_2_desc": "Lie side by side with your baby. Smile and speak lovingly as they try to turn toward you.",
  "tip_sound_hunter_listening_title": "Sound Hunter",
  "tip_sound_hunter_listening_desc": "Shake a rattle softly where your baby cannot see it. Turning toward sound builds hearing and focus.",
  "tip_sound_hunter_level2_1_2_title": "Sound Hunter (Level 2)",
  "tip_sound_hunter_level2_1_2_desc": "Make different sounds from left and right. Finding the source strengthens attention skills.",
  "tip_texture_discovery_1_2_title": "Touch and Discover",
  "tip_texture_discovery_1_2_desc": "Offer objects with different textures. Each new feeling is a new discovery for your baby.",
  "tip_outdoor_explorer_4_5_title": "Outdoor Explorer",
  "tip_outdoor_explorer_4_5_desc": "Show trees and animals outside. Let your baby touch and explore while hearing your voice.",
  "tip_reaching_exercise_1_2_title": "Reaching Practice",
  "tip_reaching_exercise_1_2_desc": "Place toys within reach. Even attempts to grab them help strengthen muscles.",
  "tip_supported_bounce_1_2_title": "Supported Bouncing",
  "tip_supported_bounce_1_2_desc": "Hold your baby upright on your lap and let them bounce gently with support. It helps leg strength and exploration.",
  "tip_visual_tracking_1_2_title": "Visual Tracking",
  "tip_visual_tracking_1_2_desc": "Move a colorful sound-making toy in slow circles within view. Eye tracking is a great visual exercise.",
  "tip_face_play_1_2_title": "Face Play",
  "tip_face_play_1_2_desc": "Get close, make eye contact, and use playful facial expressions. Your voice and face are your baby's favorite toys.",
  "tip_emotion_labeling_1_2_title": "Emotion Naming",
  "tip_emotion_labeling_1_2_desc": "When your baby cries, name the feeling kindly and reassure them. Feeling understood helps emotional safety.",
  "tip_first_meal_title": "First Tasting",
  "tip_first_meal_desc": "Start solids based on your doctor's advice. Spoon feeding can be fun, but stay alert for allergy signs.",
  "tip_hand_to_hand_transfer_4_5_title": "Active Hands",
  "tip_hand_to_hand_transfer_4_5_desc": "Around months 4-5, babies try moving objects between hands. Offer easy-to-grasp items and observe.",
  "tip_supported_sitting_4_5_title": "Supported Sitting",
  "tip_supported_sitting_4_5_desc": "Practice supported sitting with pillows. Place a toy in front to motivate balance and upper-body support.",
  "tip_feet_discovery_4_5_title": "Discovering Feet",
  "tip_feet_discovery_4_5_desc": "Your baby may catch feet and bring them to the mouth while lying down. Let feet explore different surfaces.",
  "tip_independent_play_4_5_title": "Independent Play",
  "tip_independent_play_4_5_desc": "Place a few textured toys nearby and step back a little. Independent play supports confidence.",
